{
	"schemaVersion": 1,
	"id": "soundtweaks",
	"version": "${version}",
	"name": "SoundTweaks",
	"description": "Per-sound volume control — mute, amplify or individually adjust any sound in the game.",
	"authors": [
		"scr0ols"
	],
	"contact": {
		"homepage": "https://github.com/scr0ols/SoundTweaks/wiki",
		"issues": "https://github.com/scr0ols/SoundTweaks/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/soundtweaks/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.scr0ols.soundtweaks.SoundTweaks"
		],
		"client": [
			"com.scr0ols.soundtweaks.client.SoundTweaksClient"
		]
	},
	"mixins": [
		"soundtweaks.mixins.json",
		{
			"config": "soundtweaks.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
